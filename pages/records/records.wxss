.page { min-height: 100vh; background: #EEF3FB; }
.container { min-height: 100vh; height: 100vh; background: #EEF3FB; padding: 32rpx; box-sizing: border-box; }
.custom-nav { position: fixed; top: 0; left: 0; right: 0; z-index: 30; box-sizing: border-box; background: #FFFFFF; box-shadow: 0 2rpx 16rpx rgba(15, 23, 42, 0.08); }
.nav-title { position: absolute; left: 156rpx; right: 156rpx; text-align: center; color: #0F172A; font-size: 36rpx; font-weight: 800; overflow: hidden; white-space: nowrap; text-overflow: ellipsis; }
.nav-back { position: absolute; left: 28rpx; color: #3182F7; font-size: 30rpx; font-weight: 800; display: flex; align-items: center; gap: 8rpx; line-height: 1; }
.nav-back-icon { width: 16rpx; height: 16rpx; border-left: 4rpx solid currentColor; border-bottom: 4rpx solid currentColor; transform: rotate(45deg); box-sizing: border-box; flex-shrink: 0; }
.nav-back-text { line-height: 1; }
.empty { text-align: center; color: #64748B; font-size: 32rpx; margin-top: 160rpx; }
.group { margin-bottom: 24rpx; }
.records-actions { display: flex; gap: 18rpx; margin-bottom: 24rpx; }
.records-action { flex: 1; min-height: 82rpx; border-radius: 8rpx; font-size: 28rpx; font-weight: 800; display: flex; align-items: center; justify-content: center; line-height: 1; margin: 0; padding: 0; }
.records-action::after { border: 0; }
.records-action.primary { background: #3182F7; color: #fff; }
.records-action.secondary { background: #EAF2FF; color: #1761D4; }

/* ── 组头 ── */
.group-head { min-height: var(--gh-h, 80rpx); background: #fff; border-radius: 24rpx 24rpx 0 0; display: flex; align-items: center; padding: 0 28rpx; gap: 12rpx; }
.group-head:only-child { border-radius: 24rpx; }
.date { font-size: var(--fs-date, 30rpx); color: #0F172A; font-weight: 800; flex: 1; }
.count { color: #94A3B8; font-size: var(--fs-count, 24rpx); }
.arrow { color: #94A3B8; font-size: 36rpx; font-weight: 400; line-height: 1; transform: rotate(90deg); display: inline-block; transition: transform 0.2s; }
.arrow.open { transform: rotate(270deg); }

/* ── 记录行 ── */
.record { background: #fff; border-top: 2rpx solid #EEF3FB; padding: var(--rec-py, 20rpx) 28rpx; display: flex; align-items: center; gap: 18rpx; }
.record:last-child { border-radius: 0 0 24rpx 24rpx; }

/* 左列：时间 + 早/晚测 */
.left { width: 88rpx; text-align: center; flex-shrink: 0; }
.time { display: block; color: #0F172A; font-size: var(--fs-time, 26rpx); font-weight: 700; }
.tag { display: block; margin-top: 6rpx; color: #3182F7; background: #EAF2FF; border-radius: 999rpx; font-size: var(--fs-tag, 20rpx); padding: 2rpx 8rpx; }

/* 中列：血压 + 心率 */
.main { flex: 1; min-width: 0; }
.bp { display: block; font-size: var(--fs-bp, 32rpx); font-weight: 800; }
.hr { display: block; margin-top: 6rpx; color: #64748B; font-size: var(--fs-hr, 24rpx); }

/* 右列：badge + 操作 */
.right { flex-shrink: 0; }
.right-line { display: flex; align-items: center; justify-content: flex-end; gap: 18rpx; flex-wrap: nowrap; }
.badge { font-size: var(--fs-badge, 20rpx); font-weight: 700; padding: 4rpx 16rpx; border-radius: 999rpx; }
.badge.normal  { color: #16A34A; background: #DCFCE7; }
.badge.warning { color: #D97706; background: #FEF3C7; }
.badge.danger  { color: #DC2626; background: #FEE2E2; }
.actions { display: flex; align-items: center; gap: 18rpx; font-size: 24rpx; white-space: nowrap; }
.edit { color: #3182F7; }
.delete { color: #FF3B30; }
.mask { position: fixed; inset: 0; background: rgba(15, 23, 42, 0.36); z-index: 60; }
.import-modal { position: fixed; left: 0; right: 0; bottom: 0; z-index: 61; background: #fff; border-radius: 32rpx 32rpx 0 0; padding: 36rpx 32rpx calc(36rpx + env(safe-area-inset-bottom)); box-shadow: 0 -8rpx 40rpx rgba(15, 23, 42, 0.16); box-sizing: border-box; }
.import-title { display: block; color: #0F172A; font-size: 36rpx; font-weight: 800; margin-bottom: 10rpx; }
.import-hint { display: block; color: #64748B; font-size: 25rpx; line-height: 1.5; margin-bottom: 20rpx; }
.import-textarea { width: 100%; min-height: 300rpx; background: #F8FAFF; border-radius: 8rpx; padding: 22rpx; box-sizing: border-box; color: #0F172A; font-size: 28rpx; line-height: 1.45; }
.import-actions { display: flex; gap: 18rpx; margin-top: 22rpx; }
.import-cancel, .import-confirm { flex: 1; min-height: 88rpx; border-radius: 8rpx; font-size: 30rpx; font-weight: 800; display: flex; align-items: center; justify-content: center; line-height: 1; margin: 0; padding: 0; }
.import-cancel::after, .import-confirm::after { border: 0; }
.import-cancel { background: #F1F5F9; color: #64748B; }
.import-confirm { background: #3182F7; color: #fff; }
.export-canvas { position: fixed; left: -9999px; top: -9999px; width: 750px; height: 1200px; }
