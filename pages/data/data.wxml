<view class="page fs-{{fontSizeClass}}" style="{{fontSizeStyle}}">
  <view class="custom-nav {{navScrolled ? 'scrolled' : ''}}" style="{{navStyle}}">
    <text class="nav-title" style="{{navTitleStyle}}">血压心率记录</text>
  </view>

<scroll-view scroll-y class="container" style="{{contentStyle}}" bindscroll="onDataScroll">
  <view class="hero" style="{{heroStyle}}">
    <view class="rec-card">
      <text class="rec-time">{{latestRecord ? '最近一次记录时间：' + latestTime : '本次记录时间：----'}}</text>
      <view class="rec-body">
        <view class="rec-inner">
          <view class="rec-top {{quickEntryActive && quickField==='systolic' ? 'editing' : ''}}" bindtap="onQuickFieldTap" data-field="systolic">
            <text class="rl">高压值 (mmHg)</text>
            <view class="rv-lg {{quickEntryActive ? quickBpValueClass : bpValueClass}}">
              <block wx:if="{{quickEntryActive && quickField==='systolic'}}"><text>{{quickForm.systolic || '--'}}</text><text class="blinking-cursor"></text></block>
              <block wx:elif="{{quickEntryActive}}"><text>{{quickForm.systolic || '--'}}</text></block>
              <block wx:elif="{{latestRecord}}"><text>{{latestRecord.systolic}}</text></block>
              <block wx:else><text>--</text></block>
            </view>
          </view>
          <view class="rec-bottom">
            <view class="rec-field {{quickEntryActive && quickField==='diastolic' ? 'editing' : ''}}" bindtap="onQuickFieldTap" data-field="diastolic">
              <text class="rl">低压值 (mmHg)</text>
              <view class="rv-md {{quickEntryActive ? quickBpValueClass : bpValueClass}}">
                <block wx:if="{{quickEntryActive && quickField==='diastolic'}}"><text>{{quickForm.diastolic || '--'}}</text><text class="blinking-cursor"></text></block>
                <block wx:elif="{{quickEntryActive}}"><text>{{quickForm.diastolic || '--'}}</text></block>
                <block wx:elif="{{latestRecord}}"><text>{{latestRecord.diastolic}}</text></block>
                <block wx:else><text>--</text></block>
              </view>
            </view>
            <view class="rec-field {{quickEntryActive && quickField==='heartRate' ? 'editing' : ''}}" bindtap="onQuickFieldTap" data-field="heartRate">
              <text class="rl">心率 (bpm)</text>
              <view class="rv-md {{quickEntryActive ? quickHrValueClass : hrValueClass}}">
                <block wx:if="{{quickEntryActive && quickField==='heartRate'}}"><text>{{quickForm.heartRate || '--'}}</text><text class="blinking-cursor"></text></block>
                <block wx:elif="{{quickEntryActive}}"><text>{{quickForm.heartRate || '--'}}</text></block>
                <block wx:elif="{{latestRecord}}"><text>{{latestRecord.heartRate}}</text></block>
                <block wx:else><text>--</text></block>
              </view>
            </view>
          </view>
        </view>
        <view class="bp-bar">
          <view class="bbs bbs-danger {{bpBarActive === 0 ? 'active' : ''}}"></view>
          <view class="bbs bbs-warn {{bpBarActive === 1 ? 'active' : ''}}"></view>
          <view class="bbs bbs-ok {{bpBarActive === 2 ? 'active' : ''}}"></view>
        </view>
      </view>
    </view>
    <button wx:if="{{!quickEntryActive}}" class="add" bindtap="onAddRecord">＋ 添加记录</button>
    <button wx:if="{{quickEntryActive}}" class="add add-cancel" bindtap="onCancelQuickEntry">取消录入</button>
  </view>

  <view class="toolbar">
    <view class="periods">
      <view wx:for="{{['7天','30天','90天']}}" wx:key="*this" class="period {{period===item?'active':''}}" bindtap="onPeriodChange" data-period="{{item}}">{{item}}</view>
    </view>
    <text class="all" bindtap="onAllRecords">全部记录 ></text>
  </view>

  <view class="section-head">
    <view class="section-title-wrap">
      <text class="section-title">血压数据</text>
      <text class="notice" bindtap="onBPNotice">?</text>
    </view>
    <text wx:if="{{hasChartRecords}}" class="download" bindtap="onDownloadBPChart">↓ 下载图表</text>
  </view>
  <view class="analysis-card">
    <view class="stat-row">
      <view class="stat"><text class="stat-num">{{hasChartRecords ? stats.bp.inRange : '--'}}</text><text>已达标（次）</text></view>
      <view class="stat"><text class="stat-num attention">{{hasChartRecords ? stats.bp.attention : '--'}}</text><text>不达标（次）</text></view>
      <view class="stat"><text class="stat-num small">{{hasChartRecords ? stats.avg.systolic + '/' + stats.avg.diastolic : '--'}}</text><text>均值（mmHg）</text></view>
    </view>
    <view class="chart-divider"></view>
    <canvas wx:if="{{hasChartRecords}}" id="bpChart" type="2d" class="chart-canvas"></canvas>
    <view wx:else class="chart-empty">暂无信息</view>
  </view>

  <view class="section-head">
    <view class="section-title-wrap">
      <text class="section-title">心率数据</text>
      <text class="notice" bindtap="onHRNotice">?</text>
    </view>
    <text wx:if="{{hasChartRecords}}" class="download" bindtap="onDownloadHRChart">↓ 下载图表</text>
  </view>
  <view class="analysis-card bottom">
    <view class="stat-row">
      <view class="stat"><text class="stat-num">{{hasChartRecords ? stats.hr.inRange : '--'}}</text><text>已达标（次）</text></view>
      <view class="stat"><text class="stat-num attention">{{hasChartRecords ? stats.hr.attention : '--'}}</text><text>不达标（次）</text></view>
      <view class="stat"><text class="stat-num">{{hasChartRecords ? stats.avg.heartRate : '--'}}</text><text>均值（bpm）</text></view>
    </view>
    <view class="chart-divider"></view>
    <canvas wx:if="{{hasChartRecords}}" id="hrChart" type="2d" class="chart-canvas"></canvas>
    <view wx:else class="chart-empty">暂无信息</view>
  </view>
  <view class="tabbar-spacer"></view>
  <canvas id="exportChart" type="2d" class="export-canvas"></canvas>
</scroll-view>

<input wx:if="{{quickEntryActive}}" class="quick-native-input" type="number" maxlength="3" value="{{quickInputValue}}" focus="{{quickInputFocus}}" adjust-position="{{false}}" confirm-type="done" bindinput="onQuickNativeInput" bindblur="onQuickNativeBlur" bindconfirm="onQuickNativeConfirm" />
</view>
