<scroll-view scroll-y class="container fs-{{fontSizeClass}}">
  <view class="hero">
    <text class="title">血压心率记录</text>
    <view class="device-card">
      <text wx:if="{{latestRecord}}" class="time">最近一次记录时间：{{latestTime}}</text>
      <text wx:else class="time">本次记录时间：----</text>
      <view class="device-screen">
        <text class="wave">⌁</text>
        <view class="traffic"><text></text><text></text><text></text></view>
        <view class="metric systolic">
          <text class="metric-label">高压值 (mmHg)</text>
          <view class="metric-value {{quickEntryActive ? quickBpValueClass : bpValueClass}}">
            <block wx:if="{{quickEntryActive}}">
              <block wx:if="{{quickField==='systolic'}}"><text>{{quickForm.systolic}}</text><text class="blinking-cursor"></text></block>
              <block wx:elif="{{quickForm.systolic}}"><text>{{quickForm.systolic}}</text></block>
              <block wx:else><text>--</text></block>
            </block>
            <block wx:elif="{{latestRecord}}"><text>{{latestRecord.systolic}}</text></block>
            <block wx:else><text>--</text></block>
          </view>
        </view>
        <view class="metric diastolic">
          <text class="metric-label">低压值 (mmHg)</text>
          <view class="metric-value {{quickEntryActive ? quickBpValueClass : bpValueClass}}">
            <block wx:if="{{quickEntryActive}}">
              <block wx:if="{{quickField==='diastolic'}}"><text>{{quickForm.diastolic}}</text><text class="blinking-cursor"></text></block>
              <block wx:elif="{{quickForm.diastolic}}"><text>{{quickForm.diastolic}}</text></block>
              <block wx:else><text>--</text></block>
            </block>
            <block wx:elif="{{latestRecord}}"><text>{{latestRecord.diastolic}}</text></block>
            <block wx:else><text>--</text></block>
          </view>
        </view>
        <view class="metric heart">
          <text class="metric-label">心率 (bpm)</text>
          <view class="metric-value {{quickEntryActive ? quickHrValueClass : hrValueClass}}">
            <block wx:if="{{quickEntryActive}}">
              <block wx:if="{{quickField==='heartRate'}}"><text>{{quickForm.heartRate}}</text><text class="blinking-cursor"></text></block>
              <block wx:elif="{{quickForm.heartRate}}"><text>{{quickForm.heartRate}}</text></block>
              <block wx:else><text>--</text></block>
            </block>
            <block wx:elif="{{latestRecord}}"><text>{{latestRecord.heartRate}}</text></block>
            <block wx:else><text>--</text></block>
          </view>
        </view>
      </view>
    </view>
    <button class="add" bindtap="onAddRecord">{{quickEntryActive ? '正在录入' : '＋ 添加记录'}}</button>
  </view>

  <view class="toolbar">
    <view class="periods">
      <view wx:for="{{['7天','30天','90天']}}" wx:key="*this" class="period {{period===item?'active':''}}" bindtap="onPeriodChange" data-period="{{item}}">{{item}}</view>
    </view>
    <text class="all" bindtap="onAllRecords">全部记录 ></text>
  </view>

  <view class="section-head">
    <view class="section-title-wrap">
      <view class="section-icon bp-icon"></view>
      <text class="section-title">血压数据</text>
      <text class="notice" bindtap="onBPNotice">?</text>
    </view>
    <text wx:if="{{hasChartRecords}}" class="download" bindtap="onDownloadBPChart">↓ 下载图表</text>
  </view>
  <view class="analysis-card">
    <view class="stat-row">
      <view class="stat"><text class="stat-num">{{hasChartRecords ? stats.bp.inRange : '--'}}</text><text>已达标（次）</text></view>
      <view class="stat"><text class="stat-num attention">{{hasChartRecords ? stats.bp.attention : '--'}}</text><text>不达标（次）</text></view>
      <view class="stat"><text class="stat-num small">{{hasChartRecords ? stats.avg.systolic + '/' + stats.avg.diastolic : '--'}}</text><text>均值（mmHg）</text></view>
    </view>
    <view class="chart-divider"></view>
    <canvas wx:if="{{hasChartRecords}}" id="bpChart" type="2d" class="chart-canvas"></canvas>
    <view wx:else class="chart-empty">暂无信息</view>
  </view>

  <view class="section-head">
    <view class="section-title-wrap">
      <view class="section-icon hr-icon"></view>
      <text class="section-title">心率数据</text>
      <text class="notice" bindtap="onHRNotice">?</text>
    </view>
    <text wx:if="{{hasChartRecords}}" class="download" bindtap="onDownloadHRChart">↓ 下载图表</text>
  </view>
  <view class="analysis-card bottom">
    <view class="stat-row">
      <view class="stat"><text class="stat-num">{{hasChartRecords ? stats.hr.inRange : '--'}}</text><text>已达标（次）</text></view>
      <view class="stat"><text class="stat-num attention">{{hasChartRecords ? stats.hr.attention : '--'}}</text><text>不达标（次）</text></view>
      <view class="stat"><text class="stat-num">{{hasChartRecords ? stats.avg.heartRate : '--'}}</text><text>均值（bpm）</text></view>
    </view>
    <view class="chart-divider"></view>
    <canvas wx:if="{{hasChartRecords}}" id="hrChart" type="2d" class="chart-canvas"></canvas>
    <view wx:else class="chart-empty">暂无信息</view>
  </view>
  <canvas id="exportChart" type="2d" class="export-canvas"></canvas>
</scroll-view>

<view wx:if="{{quickEntryActive}}" class="keypad-panel">
  <view class="keypad-head">
    <text>正在输入：{{quickFieldLabel}}</text>
    <text class="keypad-cancel" bindtap="onCancelQuickEntry">取消</text>
  </view>
  <view class="keypad-grid">
    <button class="key" data-value="1" bindtap="onKeypadDigit">1</button>
    <button class="key" data-value="2" bindtap="onKeypadDigit">2</button>
    <button class="key" data-value="3" bindtap="onKeypadDigit">3</button>
    <button class="key" data-value="4" bindtap="onKeypadDigit">4</button>
    <button class="key" data-value="5" bindtap="onKeypadDigit">5</button>
    <button class="key" data-value="6" bindtap="onKeypadDigit">6</button>
    <button class="key" data-value="7" bindtap="onKeypadDigit">7</button>
    <button class="key" data-value="8" bindtap="onKeypadDigit">8</button>
    <button class="key" data-value="9" bindtap="onKeypadDigit">9</button>
    <button class="key action" bindtap="onKeypadDelete">删除</button>
    <button class="key" data-value="0" bindtap="onKeypadDigit">0</button>
    <button class="key action" bindtap="onKeypadNext">下一项</button>
    <button class="key submit" loading="{{quickSaving}}" bindtap="onQuickSave">立即添加</button>
  </view>
</view>
