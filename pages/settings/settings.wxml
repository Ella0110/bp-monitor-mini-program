<view class="page" style="{{fontSizeStyle}}">
  <view class="custom-nav" style="{{navStyle}}">
    <view class="nav-back" style="{{navBackStyle}}" bindtap="onBackTap"><view class="nav-back-icon"></view><text class="nav-back-text">返回</text></view>
    <text class="nav-title" style="{{navTitleStyle}}">设置</text>
  </view>

  <scroll-view scroll-y class="container" style="{{contentStyle}}">
    <view class="settings-content">
      <view wx:if="{{!settings && !loading}}" class="empty-card">
        <text>请先保存一条记录，或查看家人的记录</text>
      </view>

      <block wx:if="{{settings}}">
        <text class="sec-label">通知设置</text>
        <view class="settings-card">
          <view class="setting-row" bindtap="onToggle" data-key="abnormalBpNotifyEnabled">
            <view>
              <text class="setting-title">异常血压通知</text>
              <text class="setting-sub">超过阈值时通知已选择成员</text>
            </view>
            <view class="switch {{settings.abnormalBpNotifyEnabled ? 'on' : ''}}"><view class="knob"></view></view>
          </view>
          <view class="setting-row" bindtap="onNotifyMembersTap">
            <view>
              <text class="setting-title">通知对象</text>
              <text class="setting-sub">血压异常时通知谁</text>
            </view>
            <text class="value">{{notifyMemberText}} ></text>
          </view>
          <view class="setting-row">
            <view>
              <text class="setting-title">高压告警阈值 (mmHg)</text>
              <text class="setting-sub">收缩压超过此值时触发通知</text>
            </view>
            <view class="stepper">
              <view class="stepper-btn" bindtap="onStepperTap" data-key="alertSystolic" data-delta="{{-5}}" data-min="{{100}}" data-max="{{200}}">－</view>
              <text class="stepper-val">{{settings.alertSystolic}}</text>
              <view class="stepper-btn" bindtap="onStepperTap" data-key="alertSystolic" data-delta="{{5}}" data-min="{{100}}" data-max="{{200}}">＋</view>
            </view>
          </view>
          <view class="setting-row no-border">
            <view>
              <text class="setting-title">低压告警阈值 (mmHg)</text>
              <text class="setting-sub">舒张压超过此值时触发通知</text>
            </view>
            <view class="stepper">
              <view class="stepper-btn" bindtap="onStepperTap" data-key="alertDiastolic" data-delta="{{-5}}" data-min="{{60}}" data-max="{{130}}">－</view>
              <text class="stepper-val">{{settings.alertDiastolic}}</text>
              <view class="stepper-btn" bindtap="onStepperTap" data-key="alertDiastolic" data-delta="{{5}}" data-min="{{60}}" data-max="{{130}}">＋</view>
            </view>
          </view>
        </view>

        <text class="sec-label">提醒设置</text>
        <view class="settings-card">
          <view class="setting-row" bindtap="onToggle" data-key="medicationReminderEnabled">
            <view>
              <text class="setting-title">用药提醒</text>
              <text class="setting-sub">每日定时提醒服药</text>
            </view>
            <view class="switch {{settings.medicationReminderEnabled ? 'on' : ''}}"><view class="knob"></view></view>
          </view>
          <picker mode="time" value="{{settings.morningReminderTime}}" bindchange="onTimeChange" data-key="morningReminderTime">
            <view class="setting-row">
              <view>
                <text class="setting-title">晨提醒时间</text>
                <text class="setting-sub">早晨服药提醒时间</text>
              </view>
              <text class="value">{{settings.morningReminderTime}} ></text>
            </view>
          </picker>
          <picker mode="time" value="{{settings.eveningReminderTime}}" bindchange="onTimeChange" data-key="eveningReminderTime">
            <view class="setting-row no-border">
              <view>
                <text class="setting-title">晚提醒时间</text>
                <text class="setting-sub">晚上服药提醒时间</text>
              </view>
              <text class="value">{{settings.eveningReminderTime}} ></text>
            </view>
          </picker>
        </view>

        <text class="sec-label">图表设置</text>
        <view class="settings-card">
          <view class="setting-row" bindtap="onToggle" data-key="morningEveningLabel">
            <view>
              <text class="setting-title">晨/晚测标注</text>
              <text class="setting-sub">录入时选择测量时段</text>
            </view>
            <view class="switch {{settings.morningEveningLabel ? 'on' : ''}}"><view class="knob"></view></view>
          </view>
          <view class="setting-row no-border" bindtap="onToggle" data-key="splitLines">
            <view>
              <text class="setting-title">早晚分线显示</text>
              <text class="setting-sub">图表中晨/晚测分两条线</text>
            </view>
            <view class="switch {{settings.splitLines ? 'on' : ''}}"><view class="knob"></view></view>
          </view>
        </view>

        <text class="sec-label">显示设置</text>
        <view class="settings-card">
          <view class="setting-row no-border">
            <view>
              <text class="setting-title">字体大小</text>
              <text class="setting-sub">超大模式适合老人使用</text>
            </view>
            <view class="segmented">
              <text class="{{settings.fontSize==='standard'?'active':''}}" bindtap="onFontSizeTap" data-value="standard">标准</text>
              <text class="{{settings.fontSize==='large'?'active':''}}" bindtap="onFontSizeTap" data-value="large">大</text>
              <text class="{{settings.fontSize==='xlarge'?'active':''}}" bindtap="onFontSizeTap" data-value="xlarge">超大</text>
            </view>
          </view>
        </view>

        <text class="sec-label">关于</text>
        <view class="settings-card">
          <view class="setting-row">
            <text class="setting-title">当前版本</text>
            <text class="value">1.0.0</text>
          </view>
          <view class="setting-row no-border" bindtap="onFeedback">
            <view>
              <text class="setting-title">意见反馈</text>
              <text class="setting-sub">复制反馈邮箱地址</text>
            </view>
            <text class="value">></text>
          </view>
        </view>

        <text class="note">当前仅保存配置，暂不接微信订阅消息或真实提醒服务。</text>
      </block>
    </view>
  </scroll-view>
</view>
