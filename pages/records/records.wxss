.container { min-height: 100vh; background: #EEF3FB; padding: 32rpx; box-sizing: border-box; }
.empty { text-align: center; color: #64748B; font-size: 32rpx; margin-top: 160rpx; }
.group { margin-bottom: 24rpx; }

/* ── 组头 ── */
.group-head { min-height: var(--gh-h, 80rpx); background: #fff; border-radius: 24rpx 24rpx 0 0; display: flex; align-items: center; padding: 0 28rpx; gap: 12rpx; }
.group-head:only-child { border-radius: 24rpx; }
.date { font-size: var(--fs-date, 30rpx); color: #0F172A; font-weight: 800; flex: 1; }
.count { color: #94A3B8; font-size: var(--fs-count, 24rpx); }
.arrow { color: #94A3B8; font-size: 36rpx; font-weight: 400; line-height: 1; transform: rotate(90deg); display: inline-block; transition: transform 0.2s; }
.arrow.open { transform: rotate(270deg); }

/* ── 记录行 ── */
.record { background: #fff; border-top: 2rpx solid #EEF3FB; padding: var(--rec-py, 20rpx) 28rpx; display: flex; align-items: center; gap: 18rpx; }
.record:last-child { border-radius: 0 0 24rpx 24rpx; }

/* 左列：时间 + 早/晚测 */
.left { width: 88rpx; text-align: center; flex-shrink: 0; }
.time { display: block; color: #0F172A; font-size: var(--fs-time, 26rpx); font-weight: 700; }
.tag { display: block; margin-top: 6rpx; color: #3182F7; background: #EAF2FF; border-radius: 999rpx; font-size: var(--fs-tag, 20rpx); padding: 2rpx 8rpx; }

/* 中列：血压 + 心率 */
.main { flex: 1; min-width: 0; }
.bp { display: block; font-size: var(--fs-bp, 32rpx); font-weight: 800; }
.hr { display: block; margin-top: 6rpx; color: #64748B; font-size: var(--fs-hr, 24rpx); }

/* 右列：badge + 操作 */
.right { display: flex; flex-direction: column; align-items: flex-end; gap: 12rpx; flex-shrink: 0; }
.badge { font-size: var(--fs-badge, 20rpx); font-weight: 700; padding: 4rpx 16rpx; border-radius: 999rpx; }
.badge.normal  { color: #16A34A; background: #DCFCE7; }
.badge.warning { color: #D97706; background: #FEF3C7; }
.badge.danger  { color: #DC2626; background: #FEE2E2; }
.actions { display: flex; gap: 24rpx; font-size: 24rpx; }
.edit { color: #3182F7; }
.delete { color: #FF3B30; }
