.page { min-height: 100vh; background: #EEF3FB; }
.container { position: fixed; left: 0; right: 0; bottom: 0; background: #EEF3FB; box-sizing: border-box; }
.report-content { padding: 28rpx 32rpx 120rpx; box-sizing: border-box; }
.custom-nav { position: fixed; top: 0; left: 0; right: 0; z-index: 30; box-sizing: border-box; background: #3182F7; box-shadow: 0 2rpx 16rpx rgba(23, 97, 212, 0.18); }
.nav-title { position: absolute; left: 156rpx; right: 156rpx; text-align: center; color: #FFFFFF; font-size: 36rpx; font-weight: 800; overflow: hidden; white-space: nowrap; text-overflow: ellipsis; }
.nav-back { position: absolute; left: 28rpx; color: #FFFFFF; font-size: 30rpx; font-weight: 800; display: flex; align-items: center; gap: 8rpx; line-height: 1; }
.nav-back-icon { width: 16rpx; height: 16rpx; border-left: 4rpx solid currentColor; border-bottom: 4rpx solid currentColor; transform: rotate(45deg); box-sizing: border-box; flex-shrink: 0; }
.nav-back-text { line-height: 1; }
.periods { display: flex; background: #EAF2FF; border-radius: 40rpx; padding: 6rpx; margin-bottom: 28rpx; }
.period { flex: 1; text-align: center; padding: 14rpx 0; color: #3182F7; border-radius: 34rpx; font-size: 28rpx; font-weight: 800; }
.period.active { background: #3182F7; color: #fff; }
.empty { margin-top: 160rpx; text-align: center; color: #64748B; font-size: 32rpx; }
.report-card { background: #fff; border-radius: 32rpx; padding: 32rpx; box-shadow: 0 4rpx 32rpx rgba(49,130,247,0.09); }
.title { display: block; color: #0F172A; font-size: 40rpx; font-weight: 900; margin-bottom: 18rpx; }
.meta { display: block; color: #64748B; font-size: 26rpx; margin-top: 8rpx; }
.section { margin-top: 40rpx; }
.section-title { display: block; color: #0F172A; font-size: 32rpx; font-weight: 900; margin-bottom: 20rpx; }
.summary-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 18rpx; }
.summary-item { background: #F8FAFC; border-radius: 20rpx; padding: 22rpx; }
.summary-value { display: block; color: #0F172A; font-size: 34rpx; font-weight: 900; }
.summary-value.warn { color: #E53935; }
.summary-label { display: block; color: #64748B; font-size: 24rpx; margin-top: 6rpx; }
.chart { width: 100%; height: 360rpx; display: block; }
.chart-empty { height: 220rpx; display: flex; align-items: center; justify-content: center; color: #64748B; font-size: 28rpx; background: #F8FAFC; border-radius: 20rpx; }
.record-empty { color: #64748B; font-size: 28rpx; padding: 20rpx 0; }
.record-row { border-top: 2rpx solid #EEF3FB; padding: 20rpx 0; }
.record-time { display: block; color: #64748B; font-size: 24rpx; }
.record-main { display: block; color: #0F172A; font-size: 30rpx; font-weight: 800; margin-top: 6rpx; }
.record-status { display: block; color: #64748B; font-size: 24rpx; margin-top: 6rpx; }
.ref-line-note { margin-top: 32rpx; background: #F8FAFC; border-radius: 16rpx; padding: 18rpx 24rpx; }
.ref-line-note-text { color: #64748B; font-size: 24rpx; line-height: 1.5; }
.disclaimer { margin-top: 40rpx; color: #64748B; font-size: 24rpx; line-height: 1.7; }
.profile-row { display: flex; align-items: flex-start; gap: 0; margin-top: 12rpx; }
.profile-label { width: 88rpx; flex-shrink: 0; font-size: 24rpx; color: #64748B; padding-top: 2rpx; }
.profile-value { flex: 1; font-size: 24rpx; color: #334155; line-height: 1.5; }
.profile-value--empty { color: #94A3B8; }
.status-card { display: flex; align-items: flex-start; gap: 16rpx; border-radius: 16rpx; padding: 24rpx 28rpx; margin-top: 32rpx; }
.status-card--normal    { background: #DCFCE7; }
.status-card--attention { background: #FEF3C7; }
.status-card--warning   { background: #FFEDD5; }
.status-card--danger    { background: #FEE2E2; }
.status-card--empty     { background: #F8FAFC; }
.status-dot { width: 18rpx; height: 18rpx; border-radius: 50%; flex-shrink: 0; margin-top: 8rpx; }
.status-card--normal    .status-dot { background: #22C55E; }
.status-card--attention .status-dot { background: #F59E0B; }
.status-card--warning   .status-dot { background: #FB923C; }
.status-card--danger    .status-dot { background: #EF4444; }
.status-card--empty     .status-dot { background: #94A3B8; }
.status-body { flex: 1; }
.status-title { display: block; font-size: 30rpx; font-weight: 800; }
.status-card--normal    .status-title { color: #15803D; }
.status-card--attention .status-title { color: #92400E; }
.status-card--warning   .status-title { color: #9A3412; }
.status-card--danger    .status-title { color: #991B1B; }
.status-card--empty     .status-title { color: #64748B; }
.status-desc { display: block; font-size: 22rpx; margin-top: 6rpx; }
.status-card--normal    .status-desc { color: #15803D; }
.status-card--attention .status-desc { color: #92400E; }
.status-card--warning   .status-desc { color: #9A3412; }
.status-card--danger    .status-desc { color: #991B1B; }
.status-card--empty     .status-desc { color: #64748B; }
.privacy-row { background: #fff; border-radius: 20rpx; padding: 24rpx 28rpx; margin-top: 20rpx; display: flex; align-items: center; justify-content: space-between; box-shadow: 0 4rpx 32rpx rgba(49,130,247,0.09); }
.privacy-label { display: block; font-size: 28rpx; font-weight: 700; color: #0F172A; }
.privacy-sub { display: block; font-size: 22rpx; color: #94A3B8; margin-top: 6rpx; }
.save { min-height: 88rpx; margin-top: 28rpx; background: #3182F7; color: #fff; border-radius: 16rpx; font-size: 30rpx; font-weight: 900; display: flex; align-items: center; justify-content: center; line-height: 1; }
.export-canvas { position: fixed; left: -9999px; top: -9999px; width: 750px; height: 1400px; }
