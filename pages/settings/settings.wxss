.container { min-height: 100vh; background: #EEF3FB; padding: 32rpx; box-sizing: border-box; }
.sec-label { display: block; font-size: var(--fs-label, 24rpx); font-weight: 700; color: #94A3B8; margin: 20rpx 0; }
.empty-card, .settings-card { background: #fff; border-radius: 28rpx; padding: 0 var(--card-px, 28rpx); margin-bottom: 28rpx; box-shadow: 0 4rpx 32rpx rgba(49,130,247,0.09); }
.empty-card { min-height: 160rpx; display: flex; align-items: center; justify-content: center; color: #64748B; font-size: 28rpx; }
.setting-row { min-height: var(--row-h, 96rpx); display: flex; align-items: center; justify-content: space-between; gap: 24rpx; border-bottom: 2rpx solid #EEF3FB; }
.setting-row.no-border { border-bottom: 0; }
.setting-title { display: block; font-size: var(--fs-title, 30rpx); font-weight: 800; color: #0F172A; }
.setting-sub { display: block; font-size: var(--fs-sub, 24rpx); color: #94A3B8; margin-top: 8rpx; line-height: 1.35; }
.value { color: #64748B; font-size: var(--fs-val, 28rpx); white-space: nowrap; }
.switch { width: 88rpx; height: 52rpx; border-radius: 26rpx; background: #CBD5E1; position: relative; flex-shrink: 0; }
.switch.on { background: #3182F7; }
.knob { width: 40rpx; height: 40rpx; background: #fff; border-radius: 50%; position: absolute; top: 6rpx; left: 6rpx; transition: left 0.18s; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.18); }
.switch.on .knob { left: 42rpx; }
.stepper { display: flex; align-items: center; gap: 0; flex-shrink: 0; background: #F1F6FF; border-radius: 18rpx; overflow: hidden; }
.stepper-btn { width: 72rpx; height: 72rpx; display: flex; align-items: center; justify-content: center; color: #3182F7; font-size: 40rpx; font-weight: 700; }
.stepper-val { min-width: 80rpx; text-align: center; color: #0F172A; font-size: var(--fs-val, 28rpx); font-weight: 800; }
.segmented { display: flex; gap: 10rpx; flex-shrink: 0; }
.segmented text { min-width: 68rpx; min-height: 56rpx; border-radius: 18rpx; padding: 0 16rpx; display: flex; align-items: center; justify-content: center; color: #64748B; background: #F1F6FF; font-size: var(--fs-seg, 26rpx); font-weight: 700; }
.segmented .active { background: #3182F7; color: #fff; }
.note { display: block; color: #94A3B8; font-size: var(--fs-note, 24rpx); line-height: 1.5; padding: 12rpx 8rpx 48rpx; }
