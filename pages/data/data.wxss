.page { min-height: 100vh; background: #EEF3FB; }
.container { min-height: 100vh; height: 100vh; background: #EEF3FB; box-sizing: border-box; }
.custom-nav { position: fixed; top: 0; left: 0; right: 0; z-index: 30; box-sizing: border-box; background: transparent; transition: background 0.18s ease, box-shadow 0.18s ease; }
.custom-nav.scrolled { background: #3182F7; box-shadow: 0 4rpx 18rpx rgba(23, 97, 212, 0.18); }
.nav-title { position: absolute; left: 132rpx; right: 132rpx; text-align: center; color: #fff; font-size: var(--fs-title, 38rpx); font-weight: 800; overflow: hidden; white-space: nowrap; text-overflow: ellipsis; }
.hero { background: linear-gradient(170deg, #72BBFF 0%, #3182F7 48%, #1761D4 100%); padding: 28rpx 28rpx var(--hero-pb, 46rpx); border-radius: 0 0 58rpx 58rpx; }

/* ── 主卡片：毛玻璃外层 ── */
.rec-card { background: rgba(255,255,255,0.16); border: 2rpx solid rgba(255,255,255,0.30); border-radius: 36rpx; padding: 28rpx 28rpx 28rpx 32rpx; margin-bottom: 28rpx; }
.rec-time { display: block; font-size: 26rpx; color: rgba(255,255,255,0.82); text-align: center; margin-bottom: 24rpx; font-weight: 600; }
.rec-body { display: flex; align-items: stretch; gap: 20rpx; }

/* ── 内层白卡 ── */
.rec-inner { flex: 1; background: rgba(255,255,255,0.90); border-radius: 24rpx; padding: 28rpx 32rpx; min-width: 0; }
.rec-top { margin-bottom: 20rpx; }
.rec-bottom { display: flex; }
.rec-field { flex: 1; min-width: 0; }
.editing .rl { color: #3182F7; }

/* ── 指标标签 ── */
.rl { display: block; color: #5F7188; font-size: 26rpx; font-weight: 700; line-height: 1.35; margin-bottom: 6rpx; }

/* ── 指标数值 ── */
.rv-lg { display: flex; align-items: flex-end; font-size: var(--fs-metric-sys, 88rpx); font-weight: 900; line-height: 0.94; color: #7B8FA4; }
.rv-md { display: flex; align-items: flex-end; font-size: var(--fs-metric, 78rpx); font-weight: 900; line-height: 0.94; color: #7B8FA4; }
.rv-lg.empty, .rv-md.empty { color: #7B8FA4; }
.rv-lg.normal, .rv-md.normal { color: #22C55E; }
.rv-lg.warning, .rv-md.warning { color: #FF9500; }
.rv-lg.danger, .rv-md.danger { color: #FF3B30; }

/* ── 光标动画 ── */
.blinking-cursor { width: 5rpx; height: 70rpx; background: #3182F7; border-radius: 4rpx; margin-left: 8rpx; margin-bottom: 2rpx; animation: cursorBlink 0.9s steps(2, start) infinite; }
@keyframes cursorBlink { 50% { opacity: 0; } }

/* ── BP 状态条（右侧） ── */
.bp-bar { width: 16rpx; border-radius: 8rpx; overflow: hidden; display: flex; flex-direction: column; flex-shrink: 0; }
.bbs { flex: 1; opacity: 0.22; }
.bbs.active { opacity: 1; }
.bbs-danger { background: #FF3B30; }
.bbs-warn { background: #FF9500; }
.bbs-ok { background: #22C55E; }

/* ── 添加按钮 ── */
.add { height: 96rpx; line-height: 1; padding: 0; margin-top: 20rpx; background: #fff; color: #3182F7; border-radius: 28rpx; font-size: var(--fs-add, 28rpx); font-weight: 800; display: flex; align-items: center; justify-content: center; }
.add-cancel { background: rgba(255,255,255,0.22); color: rgba(255,255,255,0.92); border: 2rpx solid rgba(255,255,255,0.40); }
.no-write-tip { margin-top: 20rpx; display: flex; flex-direction: column; align-items: center; gap: 10rpx; padding: 24rpx 0; }
.no-write-tip__text { font-size: var(--fs-add, 28rpx); color: rgba(255,255,255,0.90); font-weight: 600; }
.no-write-tip__sub { font-size: var(--fs-time, 24rpx); color: rgba(255,255,255,0.65); }

/* ── 工具栏 / 周期选择 ── */
.toolbar { display: flex; align-items: center; justify-content: space-between; padding: 32rpx 32rpx 26rpx; }
.periods { display: flex; align-items: center; gap: 18rpx; }
.period { min-width: 76rpx; min-height: 52rpx; padding: 0 18rpx; color: #3182F7; border-radius: 30rpx; font-size: 26rpx; font-weight: 700; display: flex; align-items: center; justify-content: center; }
.period.active { background: #3182F7; color: #fff; }
.all { color: #3182F7; font-size: var(--fs-all, 28rpx); font-weight: 700; }

/* ── 图表区 ── */
.section-head { display: flex; align-items: center; justify-content: space-between; gap: 12rpx; padding: 10rpx 32rpx 18rpx; }
.section-title-wrap { display: flex; align-items: center; gap: 12rpx; min-width: 0; }
.section-title { font-size: var(--fs-section, 32rpx); color: #0F172A; font-weight: 800; }
.notice { width: 36rpx; height: 36rpx; border-radius: 50%; background: #EAF2FF; color: #3182F7; display: flex; align-items: center; justify-content: center; font-size: 24rpx; font-weight: 800; }
.download { color: #3182F7; font-size: 26rpx; font-weight: 800; flex-shrink: 0; }
.analysis-card { margin: 0 32rpx 34rpx; background: #fff; border-radius: 32rpx; padding: 30rpx 30rpx 24rpx; box-shadow: 0 8rpx 34rpx rgba(49,130,247,0.08); }
.stat-row { display: flex; justify-content: space-between; padding: 0 0 26rpx; }
.stat { flex: 1; text-align: center; color: #90A1B7; font-size: var(--fs-stat, 24rpx); font-weight: 600; }
.stat-num { display: block; color: #0F172A; font-size: var(--fs-stat-num, 48rpx); font-weight: 900; margin-bottom: 10rpx; }
.stat-num.attention { color: #FF3B30; }
.stat-num.small { font-size: var(--fs-stat-num-sm, 36rpx); }
.chart-divider { height: 2rpx; background: #EEF3FB; margin-bottom: 22rpx; }
.chart-canvas { width: 100%; height: 336rpx; display: block; }
.chart-empty { height: 280rpx; display: flex; align-items: center; justify-content: center; color: #8FA1B4; font-size: var(--fs-empty, 32rpx); }
.export-canvas { position: fixed; left: -9999px; top: -9999px; width: 750px; height: 900px; }
.bottom { margin-bottom: 34rpx; }
.tabbar-spacer { height: calc(136rpx + env(safe-area-inset-bottom)); }
.quick-native-input { position: fixed; left: 0; bottom: 0; width: 2rpx; height: 2rpx; opacity: 0; pointer-events: none; color: transparent; background: transparent; border: 0; }
