<view class="page">
  <view class="custom-nav" style="{{navStyle}}">
    <view class="nav-back" style="{{navBackStyle}}" bindtap="onBackTap"><view class="nav-back-icon"></view><text class="nav-back-text">返回</text></view>
    <text class="nav-title" style="{{navTitleStyle}}">就诊报告</text>
  </view>

  <scroll-view scroll-y class="container" style="{{contentStyle}}">
    <view class="report-content">
      <view class="periods">
        <view wx:for="{{periods}}" wx:key="*this" class="period {{period===item?'active':''}}" bindtap="onPeriodChange" data-period="{{item}}">{{item}}</view>
      </view>

      <view wx:if="{{error}}" class="empty">{{error}}</view>

      <view wx:if="{{report}}" class="report-card">
        <text class="title">{{report.title}}</text>
        <text class="meta">{{report.familyName}}</text>
        <text class="meta">{{report.periodTitle}} · 生成时间 {{report.generatedAt}}</text>

        <view class="section">
          <text class="section-title">患者档案</text>
          <view class="profile-row">
            <text class="profile-label">姓名</text>
            <text class="profile-value {{report.profileName === '未设置' ? 'profile-value--empty' : ''}}">{{report.profileName}}{{report.profileAge ? '（' + report.profileAge + '）' : ''}}</text>
          </view>
          <view class="profile-row">
            <text class="profile-label">用药</text>
            <text class="profile-value {{report.profileMedications ? '' : 'profile-value--empty'}}">{{report.profileMedications || '未填写'}}</text>
          </view>
          <view class="profile-row" wx:if="{{report.profileEmergencyName || report.profileEmergencyPhone}}">
            <text class="profile-label">联系人</text>
            <text class="profile-value">{{report.profileEmergencyName}}{{report.profileEmergencyPhone ? '  ' + report.profileEmergencyPhone : ''}}</text>
          </view>
        </view>

        <view class="status-card status-card--{{statusLevel}}">
          <view class="status-dot"></view>
          <view class="status-body">
            <text class="status-title">{{statusTitle}}</text>
            <text class="status-desc">{{statusDesc}}</text>
          </view>
        </view>

        <view class="section">
          <text class="section-title">摘要</text>
          <view class="summary-grid">
            <view class="summary-item"><text class="summary-value">{{report.avg.systolic}}/{{report.avg.diastolic}}</text><text class="summary-label">血压均值 mmHg</text></view>
            <view class="summary-item"><text class="summary-value">{{report.avg.heartRate}}</text><text class="summary-label">心率均值 bpm</text></view>
            <view class="summary-item"><text class="summary-value {{report.stats.bp.attention > 0 ? 'warn' : ''}}">{{report.stats.bp.attention}}/{{report.totalCount}}次</text><text class="summary-label">血压超参考</text></view>
            <view class="summary-item"><text class="summary-value {{report.stats.hr.attention > 0 ? 'warn' : ''}}">{{report.stats.hr.attention}}/{{report.totalCount}}次</text><text class="summary-label">心率超参考</text></view>
          </view>
        </view>

        <view class="section">
          <text class="section-title">血压趋势</text>
          <view wx:if="{{isSparseData}}" class="sparse-view">
            <view wx:for="{{report.recentRecords}}" wx:key="id" class="sparse-row">
              <text class="sparse-time">{{item.time}}</text>
              <text class="sparse-bp">{{item.bpText}}</text>
              <text class="sparse-status">血压{{item.bpStatus}}</text>
            </view>
          </view>
          <canvas wx:elif="{{report.bpChart.records.length}}" id="reportBPChart" type="2d" class="chart"></canvas>
          <view wx:else class="chart-empty">当前周期暂无记录</view>
        </view>

        <view class="section">
          <text class="section-title">心率趋势</text>
          <view wx:if="{{isSparseData}}" class="sparse-view">
            <view wx:for="{{report.recentRecords}}" wx:key="id" class="sparse-row">
              <text class="sparse-time">{{item.time}}</text>
              <text class="sparse-bp">{{item.heartRateText}}</text>
              <text class="sparse-status">心率{{item.hrStatus}}</text>
            </view>
          </view>
          <canvas wx:elif="{{report.hrChart.records.length}}" id="reportHRChart" type="2d" class="chart"></canvas>
          <view wx:else class="chart-empty">当前周期暂无记录</view>
        </view>

        <view wx:if="{{report.refLineText}}" class="ref-line-note">
          <text class="ref-line-note-text">{{report.refLineText}}</text>
        </view>

        <view class="section">
          <text class="section-title">最近记录</text>
          <view wx:if="{{!report.recentRecords.length}}" class="record-empty">当前周期暂无记录</view>
          <view wx:for="{{report.recentRecords}}" wx:key="id" class="record-row">
            <text class="record-time">{{item.time}}</text>
            <text class="record-main">{{item.bpText}} · {{item.heartRateText}}</text>
            <text class="record-status">血压{{item.bpStatus}} · 心率{{item.hrStatus}}</text>
          </view>
        </view>

        <view class="disclaimer">{{report.disclaimer}}</view>
      </view>

      <view wx:if="{{report}}" class="privacy-row">
        <view>
          <text class="privacy-label">隐藏姓名和联系人</text>
          <text class="privacy-sub">导出图片中显示为 ***</text>
        </view>
        <switch checked="{{hidePrivacy}}" bindchange="onTogglePrivacy" color="#3182F7" />
      </view>
      <button wx:if="{{report}}" class="save" bindtap="onSaveReport">保存报告图片</button>
      <canvas id="reportExportCanvas" type="2d" class="export-canvas"></canvas>
    </view>
  </scroll-view>
</view>
