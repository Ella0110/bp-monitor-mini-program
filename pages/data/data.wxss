.container { min-height: 100vh; background: #EEF3FB; }
.hero { background: linear-gradient(170deg, #72BBFF 0%, #3182F7 45%, #1A5FCC 100%); padding: 88rpx 32rpx 46rpx; border-radius: 0 0 48rpx 48rpx; }
.title { display: block; text-align: center; color: #fff; font-size: 38rpx; font-weight: 800; margin-bottom: 28rpx; }
.device-card { border-radius: 32rpx; padding: 22rpx; background: rgba(255,255,255,0.28); border: 2rpx solid rgba(255,255,255,0.42); box-shadow: 0 8rpx 32rpx rgba(19, 102, 216, 0.22); }
.time { display: block; color: rgba(255,255,255,0.92); font-size: 26rpx; text-align: center; margin-bottom: 18rpx; font-weight: 700; }
.device-screen { position: relative; min-height: 300rpx; background: #EEF4FB; border-radius: 24rpx; padding: 34rpx 40rpx; overflow: hidden; display: grid; grid-template-columns: 1fr 1fr; grid-template-rows: 1fr 1fr; gap: 22rpx 28rpx; }
.wave { position: absolute; top: 36rpx; right: 58rpx; color: #C8D2DF; font-size: 52rpx; font-weight: 900; line-height: 1; transform: rotate(180deg); }
.traffic { position: absolute; top: 34rpx; right: 18rpx; bottom: 34rpx; width: 12rpx; border-radius: 8rpx; overflow: hidden; display: flex; flex-direction: column; }
.traffic text { flex: 1; display: block; }
.traffic text:nth-child(1) { background: #D8C0F2; }
.traffic text:nth-child(2) { background: #FF9500; }
.traffic text:nth-child(3) { background: #57BCD1; }
.metric { min-width: 0; }
.metric.heart { align-self: end; }
.metric-label { display: block; color: #5F7188; font-size: 26rpx; line-height: 1.35; font-weight: 700; margin-bottom: 4rpx; }
.metric-value { min-height: 78rpx; display: flex; align-items: flex-end; color: #7B8FA4; font-size: 76rpx; font-weight: 900; line-height: 0.95; }
.metric-value.orange { color: #FF9500; }
.metric-value.green { color: #22C55E; }
.blinking-cursor { width: 5rpx; height: 70rpx; background: #3182F7; border-radius: 4rpx; margin-left: 8rpx; margin-bottom: 2rpx; animation: cursorBlink 0.9s steps(2, start) infinite; }
@keyframes cursorBlink { 50% { opacity: 0; } }
.add { min-height: 96rpx; background: #fff; color: #3182F7; border-radius: 24rpx; margin-top: 24rpx; font-size: 34rpx; font-weight: 800; }
.toolbar { display: flex; align-items: center; justify-content: space-between; padding: 28rpx 32rpx; }
.periods { display: flex; background: #EAF2FF; border-radius: 40rpx; padding: 6rpx; }
.period { padding: 12rpx 28rpx; color: #3182F7; border-radius: 34rpx; font-size: 26rpx; font-weight: 700; }
.period.active { background: #3182F7; color: #fff; }
.all { color: #3182F7; font-size: 28rpx; font-weight: 700; }
.section-head { display: flex; align-items: center; justify-content: space-between; gap: 12rpx; padding: 12rpx 32rpx 18rpx; }
.section-title-wrap { display: flex; align-items: center; gap: 12rpx; min-width: 0; }
.section-title { font-size: 32rpx; color: #0F172A; font-weight: 800; }
.notice { width: 36rpx; height: 36rpx; border-radius: 50%; background: #EAF2FF; color: #3182F7; display: flex; align-items: center; justify-content: center; font-size: 24rpx; font-weight: 800; }
.download { color: #3182F7; font-size: 26rpx; font-weight: 800; flex-shrink: 0; }
.stat-card { margin: 0 32rpx 32rpx; background: #fff; border-radius: 32rpx; padding: 32rpx 16rpx; display: flex; justify-content: space-between; box-shadow: 0 4rpx 32rpx rgba(49,130,247,0.09); }
.stat { flex: 1; text-align: center; color: #64748B; font-size: 24rpx; }
.stat-num { display: block; color: #0F172A; font-size: 48rpx; font-weight: 900; margin-bottom: 10rpx; }
.stat-num.attention { color: #FF3B30; }
.stat-num.small { font-size: 36rpx; }
.chart-card { margin: -12rpx 32rpx 32rpx; background: #fff; border-radius: 32rpx; padding: 24rpx; box-shadow: 0 4rpx 32rpx rgba(49,130,247,0.09); }
.chart-canvas { width: 100%; height: 360rpx; display: block; }
.chart-empty { height: 280rpx; display: flex; align-items: center; justify-content: center; color: #8FA1B4; font-size: 32rpx; }
.export-canvas { position: fixed; left: -9999px; top: -9999px; width: 750px; height: 900px; }
.bottom { margin-bottom: 160rpx; }
.keypad-panel { position: fixed; left: 0; right: 0; bottom: 0; z-index: 20; background: rgba(255,255,255,0.98); border-radius: 28rpx 28rpx 0 0; padding: 22rpx 28rpx calc(28rpx + env(safe-area-inset-bottom)); box-shadow: 0 -8rpx 40rpx rgba(15, 23, 42, 0.18); }
.keypad-head { display: flex; align-items: center; justify-content: space-between; color: #64748B; font-size: 26rpx; font-weight: 700; margin-bottom: 18rpx; }
.keypad-cancel { color: #3182F7; font-weight: 800; }
.keypad-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12rpx; }
.key { min-height: 86rpx; border-radius: 16rpx; background: #F7FBFF; color: #0F172A; border: 2rpx solid #DDE9F7; font-size: 36rpx; font-weight: 800; display: flex; align-items: center; justify-content: center; line-height: 1; margin: 0; }
.key::after { border: 0; }
.key.action { background: #EAF2FF; color: #3182F7; font-size: 28rpx; }
.key.submit { grid-column: span 3; background: #3182F7; color: #fff; border-color: #3182F7; font-size: 32rpx; }
