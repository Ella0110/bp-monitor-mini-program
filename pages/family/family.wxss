.container { min-height: 100vh; background: #EEF3FB; }
.fam-header { background: #fff; padding: 24rpx 40rpx 20rpx; border-bottom: 2rpx solid #DDE6F5; display: flex; align-items: center; justify-content: flex-end; }
.settings-entry { width: 64rpx; height: 64rpx; border-radius: 50%; background: #EAF2FF; color: #64748B; display: flex; align-items: center; justify-content: center; font-size: 34rpx; font-weight: 800; }
.empty { padding: 120rpx 40rpx; text-align: center; }
.empty-title { display: block; font-size: 34rpx; font-weight: 700; color: #0F172A; margin-bottom: 40rpx; }
.empty-hint { display: block; color: #64748B; font-size: 26rpx; line-height: 1.6; margin-top: 28rpx; }
.primary, .secondary { min-height: 96rpx; border-radius: 28rpx; font-size: 32rpx; font-weight: 700; margin-top: 20rpx; }
.primary { background: #3182F7; color: #fff; }
.secondary { background: #EAF2FF; color: #3182F7; }
.secondary.compact { min-height: 80rpx; border-radius: 22rpx; font-size: 28rpx; margin-top: 24rpx; }
.body { padding: 32rpx; }
.card, .action-card { background: #fff; border-radius: 32rpx; padding: 32rpx; margin-bottom: 24rpx; box-shadow: 0 4rpx 32rpx rgba(49,130,247,0.09); }
.card-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 18rpx; }
.section-title { display: block; font-size: 36rpx; font-weight: 800; color: #0F172A; margin-bottom: 12rpx; }
.card-head .section-title { margin-bottom: 0; }
.link { font-size: 28rpx; font-weight: 700; color: #3182F7; }
.profile-grid { display: flex; flex-direction: column; gap: 18rpx; color: #0F172A; font-size: 30rpx; line-height: 1.45; }
.profile-empty { display: flex; flex-direction: column; gap: 12rpx; }
.profile-empty-title { color: #0F172A; font-size: 30rpx; font-weight: 800; }
.profile-empty-sub { color: #64748B; font-size: 28rpx; line-height: 1.5; }
.trust-hint { display: block; color: #94A3B8; font-size: 24rpx; line-height: 1.5; margin-top: 20rpx; }
.row-title { font-size: 32rpx; font-weight: 700; color: #0F172A; margin-bottom: 24rpx; }
.member-row { display: flex; gap: 20rpx; overflow-x: auto; padding-bottom: 8rpx; }
.member { min-width: 112rpx; display: flex; flex-direction: column; align-items: center; gap: 10rpx; color: #64748B; font-size: 24rpx; }
.avatar { width: 96rpx; height: 96rpx; border-radius: 50%; background: #EAF2FF; color: #3182F7; display: flex; align-items: center; justify-content: center; font-size: 32rpx; font-weight: 700; }
.invite-button { min-width: 112rpx; height: 132rpx; border-radius: 24rpx; font-size: 24rpx; line-height: 1.4; white-space: pre-line; background: #3182F7; color: #fff; }
.action-title { display: block; font-size: 32rpx; font-weight: 700; color: #0F172A; margin-bottom: 8rpx; }
.disabled { opacity: 0.55; }
.mask { position: fixed; inset: 0; background: rgba(15, 23, 42, 0.35); z-index: 10; }
.setting-row { min-height: 112rpx; display: flex; align-items: center; justify-content: space-between; gap: 24rpx; border-bottom: 2rpx solid #EEF3FB; }
.setting-row.no-border { border-bottom: 0; }
.setting-title { display: block; font-size: 30rpx; font-weight: 800; color: #0F172A; }
.setting-sub { display: block; font-size: 24rpx; color: #94A3B8; margin-top: 8rpx; line-height: 1.35; }
.switch { width: 88rpx; height: 52rpx; border-radius: 26rpx; background: #CBD5E1; position: relative; flex-shrink: 0; }
.switch.on { background: #3182F7; }
.knob { width: 40rpx; height: 40rpx; background: #fff; border-radius: 50%; position: absolute; top: 6rpx; left: 6rpx; transition: left 0.18s; box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.18); }
.switch.on .knob { left: 42rpx; }
.segmented { display: flex; gap: 10rpx; flex-shrink: 0; }
.segmented text { min-width: 68rpx; min-height: 56rpx; border-radius: 18rpx; padding: 0 16rpx; display: flex; align-items: center; justify-content: center; color: #64748B; background: #F1F6FF; font-size: 26rpx; font-weight: 700; }
.segmented .active { background: #3182F7; color: #fff; }
.modal { position: fixed; left: 32rpx; right: 32rpx; bottom: 56rpx; z-index: 11; background: #fff; border-radius: 32rpx; padding: 32rpx; box-shadow: 0 10rpx 60rpx rgba(15, 23, 42, 0.20); }
.modal-title { display: block; font-size: 36rpx; font-weight: 800; color: #0F172A; margin-bottom: 24rpx; }
.modal-sub { display: block; font-size: 26rpx; color: #64748B; line-height: 1.5; margin-bottom: 14rpx; }
.modal input { min-height: 88rpx; border-radius: 20rpx; background: #F8FAFF; padding: 0 24rpx; margin-bottom: 16rpx; font-size: 30rpx; box-sizing: border-box; }
.share-panel { position: fixed; left: 24rpx; right: 24rpx; bottom: 48rpx; z-index: 11; }
.sheet-button { min-height: 96rpx; border-radius: 24rpx; font-size: 32rpx; font-weight: 700; margin-top: 16rpx; background: #fff; color: #0F172A; }
.primary-sheet { background: #3182F7; color: #fff; }
.cancel { color: #64748B; }
